# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Set to your MongoDB Atlas URI for production/Atlas vector search, or a local MongoDB URI
MONGODB_URI=mongodb://127.0.0.1:27017/high-ecommerce

# Redis Connection
# Set to your Redis server URL (e.g. redis://localhost:6379)
REDIS_URL=redis://127.0.0.1:6379

# Vector Search Configuration
# Modes: "local" (calculates cosine similarity in Node.js) or "atlas" (uses Atlas Vector Search index)
VECTOR_SEARCH_MODE=local
